# העתק קובץ זה לשם ".env" באותה תיקייה והדבק מפתחות (בלי מרכאות).
# קובץ .env מופיע ב-.gitignore ולא אמור להידחף לגיטהאב.

# Gemini (מ-Google AI Studio): אחד מהשניים מספיק
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# מודל ג'מיני (אופציונלי — בקוד ברירת מחדל gemini-2.5-flash)
# gemini-1.5-flash מחזיר 404 — לא בשימוש
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODEL=gemini-2.5-flash-lite

# Claude (אופציונלי; רק אם מריצים עם --llm anthropic)
# ANTHROPIC_API_KEY=
